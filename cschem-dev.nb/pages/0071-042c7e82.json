      "split": [ ],
      "uuid": "5de02e70",
      "y0": 269.328,
      "cc": [
        { "typ": "text",
          "cre": "2026-06-07T17:25:59.985",
          "mod": "2026-06-07T17:26:51.398",
          "lines": [
            0,
            48,
            108,
            170
          ],
          "text": "This is good. Perfectly workable on my PC. Next improvement would be to have EData copy the Group, pass the work on to a thread that can be canceled, and take the result off-line.",
          "uuid": "872d08c9"
        }
      ]
    },
    { "typ": "textblock",
      "cre": "2026-06-07T17:40:07.541",
      "mod": "2026-06-07T17:44:08.590",
      "h": 166.162,
      "ind": 1,
      "sheet": 0,
      "split": [ ],
      "uuid": "ef566984",
      "y0": 365.992,
      "cc": [
        { "typ": "text",
          "cre": "2026-06-07T17:40:07.541",
          "mod": "2026-06-07T17:44:08.590",
          "lines": [
            0,
            59,
            121,
            186,
            249,
            311,
            369
          ],
          "text": "Not needed. Instead, inserted a 1-ms delay between receipt of mouse move event and call of updateonnet. Then, if another mouse move event comes first, I cancel the timer and restart it. That way, the system is very responsive, but there is no build-up of a backlog, because the request to updateonnet is always moved to the back of the queue if there is a pending move event.",
          "uuid": "36289263"
        }
      ]
    },
    { "typ": "textblock",
      "cre": "2026-06-07T17:44:09.159",
