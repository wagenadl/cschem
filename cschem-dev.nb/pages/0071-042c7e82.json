      "split": [ ],
      "uuid": "552baa52",
      "y0": 218.996,
      "cc": [
        { "typ": "text",
          "cre": "2026-06-07T16:52:05.617",
          "mod": "2026-06-07T16:52:42.088",
          "lines": [
            0,
            59
          ],
          "text": "Then I made the NetGraph slightly faster by using an rtree to find overlapping rectangles.",
          "uuid": "2d52a42c"
        }
      ]
    },
    { "typ": "textblock",
      "cre": "2026-06-07T17:25:59.985",
      "mod": "2026-06-07T17:26:51.398",
      "h": 96.664,
      "ind": 1,
