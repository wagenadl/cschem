          "text": "#include <iostream>\n#include <vector>\n#include <boost/graph/adjacency_list.hpp>\n#include <boost/graph/breadth_first_search.hpp>\n\n// Define our graph type\ntypedef boost::adjacency_list<boost::vecS, boost::vecS, boost::undirectedS> Graph;\n\n// Create a custom visitor that records discovered nodes\nstruct connection_recorder : public boost::default_bfs_visitor {\n    std::vector<int>& connected_nodes;\n    \n    connection_recorder(std::vector<int>& nodes) : connected_nodes(nodes) {}\n\n    // This event triggers every time BFS finds a new reachable vertex\n    template <typename Vertex, typename GraphType>\n    void discover_vertex(Vertex u, const GraphType& g) const {\n        connected_nodes.push_back(u);\n    }\n};\n\nint main() {\n    // Graph with 6 nodes: (0-1-2) and (3-4), 5 is isolated\n    Graph g(6);\n    boost::add_edge(0, 1, g);\n    boost::add_edge(1, 2, g);\n    boost::add_edge(3, 4, g);\n\n    int seed_node = 0;\n    std::vector<int> result;\n\n    // Run BFS starting exactly at the seed node\n    // boost::visitor() hooks our recorder into the search loop\n    boost::breadth_first_search(g, seed_node, \n        boost::visitor(connection_recorder(result))\n    );\n\n    // Print all nodes in the same component\n    std::cout << \"Nodes connected to \" << seed_node << \": \";\n    for (int node : result) {\n        std::cout << node << \" \";\n    }\n    std::cout << \"\\n\"; // Outputs: 0 1 2\n\n    return 0;\n}",
