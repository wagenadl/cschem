          "text": "#include <iostream>\n#include <vector>\n#include <utility>\n#include <boost/graph/adjacency_list.hpp>\n#include <boost/graph/connected_components.hpp>\n\nint main() {\n    // 1. Define your graph size and your sparse edges\n    // Let's assume V = 6 nodes. \n    // Edges exist between: (0-1), (1-2), and (3-4). Node 5 is completely isolated.\n    const int V = 6;\n    std::vector<std::pair<int, int>> sparse_edges = {\n        {0, 1}, {1, 2}, {3, 4}\n    };\n\n    // 2. Define the Boost Adjacency List Type\n    // - vecS: Store edge lists in a std::vector\n    // - vecS: Store vertex lists in a std::vector\n    // - undirectedS: This is an undirected graph\n    // - no_property: We don't need custom data on the edges\n    // - boost::property<boost::vertex_rank_t, int>: A built-in property slot to store component IDs\n    typedef boost::adjacency_list<\n        boost::vecS, \n        boost::vecS, \n        boost::undirectedS, \n        boost::no_property, \n        boost::property<boost::vertex_rank_t, int>\n    > SparseGraph;\n\n    // 3. Instantiate and populate the graph\n    // We pass the edge iterators and the total vertex count to the constructor.\n    SparseGraph g(sparse_edges.begin(), sparse_edges.end(), V);\n\n    // 4. Run the Connected Components algorithm\n    // We get a \"property map\" that links each vertex to its vertex_rank_t (which we use for component ID)\n    auto component_map = boost::get(boost::vertex_rank, g);\n    int num_components = boost::connected_components(g, component_map);\n\n    std::cout << \"Total connected components found: \" << num_components << \"\\n\\n\";\n\n    // 5. Generate the Connection Matrix\n    // Even though the graph is sparse, the final requested reachability matrix is V x V.\n    // If two nodes share the same component ID, they can reach each other.\n    std::vector<std::vector<int>> connection_matrix(V, std::vector<int>(V, 0));\n    \n    for (int i = 0; i < V; ++i) {\n        for (int j = 0; j < V; ++j) {\n            if (component_map[i] == component_map[j]) {\n                connection_matrix[i][j] = 1;\n            }\n        }\n    }\n\n    // Print the final Connection Matrix\n    std::cout << \"Connection Matrix:\\n\";\n    for (const auto& row : connection_matrix) {\n        for (int val : row) {\n            std::cout << val << \" \";\n        }\n        std::cout << \"\\n\";\n    }\n\n    return 0;\n}",
          "uuid": "51a9da8d",
          "cc": [
